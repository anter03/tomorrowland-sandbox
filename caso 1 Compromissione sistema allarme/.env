# ==============================================================================
# CONFIGURAZIONE DI SICUREZZA
# ==============================================================================

# Chiave crittografica nativa del festival
SECRET_KEY=chiave_segreta_del_festival

# Disabilitazione della verifica temporale per simulare CWE-613
VERIFY_EXPIRATION=false

# INTERRUTTORE DELLA VULNERABILITÀ
# false = Scenario Vulnerabile (CWE-862 attivo - per attacco TAD)
# true  = Scenario Sicuro (CTRL-C01 forzato - per difesa/mitigazione)
VULNERABILITY_ENABLED=true